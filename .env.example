# ============================================
# INSTA-DATA — Environment Variables
# ============================================
# ВАЖНО: Не передаємо пароліці в git!
# Скопіюй в .env та заповни значення
# ============================================

# 📱 Instagram Credentials
INSTAGRAM_EMAIL=Niobium_Runas
INSTAGRAM_PASSWORD=your_password_here  # НЕ КОМІТИТИ!
INSTAGRAM_SESSION_FILE=./backend/instagram_session.json

# 🗄️ MongoDB
MONGODB_URL=mongodb://mongo:27017
MONGODB_DB=insta_data
MONGODB_USER=admin
MONGODB_PASSWORD=your_mongo_password  # НЕ КОМІТИТИ!

# 🐘 PostgreSQL
POSTGRES_URL=postgresql://admin:your_postgres_password@postgres:5432/insta_data_history
POSTGRES_USER=admin
POSTGRES_PASSWORD=your_postgres_password  # НЕ КОМІТИТИ!
POSTGRES_DB=insta_data_history

# 🔴 Redis
REDIS_URL=redis://redis:6379
REDIS_DB=0

# 🌐 Backend API
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=true
ENVIRONMENT=development  # development, staging, production

# 🔑 API Security
SECRET_KEY=your_secret_key_here  # НЕ КОМІТИТИ!
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# 🚀 Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=Insta-Data

# 📧 Email (if needed for future)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password  # НЕ КОМІТИТИ!

# 🔔 Logging
LOG_LEVEL=INFO
LOG_FORMAT=json  # json або text

# 🎨 UI Settings
TAILWIND_MODE=jit
NEXT_PUBLIC_DEFAULT_LANGUAGE=ukr  # ukr, rus, mne

# ⚙️ Scraper Settings
SCRAPER_TIMEOUT=30
SCRAPER_RETRY_ATTEMPTS=3
SCRAPER_INSTAGRAM_MAX_POSTS=100
SCRAPER_UPDATE_INTERVAL_HOURS=24
SCRAPER_INSTAGRAM_ENABLED=true
SCRAPER_AROMA_ENABLED=true
SCRAPER_VOLI_ENABLED=true
SCRAPER_HDL_ENABLED=true
SCRAPER_IDEA_ENABLED=true

# 🖼️ Image Processing
IMAGE_MAX_WIDTH=500
IMAGE_MAX_HEIGHT=500
IMAGE_QUALITY=85
IMAGE_FORMAT=jpeg

# 📊 Database Retention
PRICE_HISTORY_RETENTION_DAYS=365
SCRAPED_DATA_RETENTION_DAYS=90

# 🔗 External APIs (if needed)
SENTRY_DSN=  # Error tracking (optional)